# 🏔️ Sahyadri Saathi — Environment Template Configuration
# Copy this file to '.env' and fill in your actual private credentials.

# Node Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# MongoDB Connection (Rename database target if needed)
# Example: mongodb+srv://username:password@cluster.mongodb.net/SahyadriSaathi?retryWrites=true&w=majority
DATABASE=mongodb://localhost:27017/SahyadriSaathi
DATABASE_PASSWORD=your_database_password

# Authentication (JWT Secrets)
JWT_SECRET=your_jwt_signing_secret_min_32_chars
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90d

# Stripe Payment Gateway
STRIPE_PUBLISHABLE_KEY=pk_test_yourStripePublishableKey
STRIPE_SECRET_KEY=sk_test_yourStripeSecretKey
STRIPE_CURRENCY=inr
STRIPE_WEBHOOK_SECRET=whsec_yourStripeWebhookSecret

# Email Notification Delivery (SendGrid or Mailtrap)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USERNAME=apikey
EMAIL_PASSWORD=your_sendgrid_api_key_or_smtp_password
EMAIL_FROM=notifications@sahyadrisaathi.com

# Platform Commission
PLATFORM_COMMISSION_RATE=0.15
